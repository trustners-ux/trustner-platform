# ============================================================================
# TRUSTNER PARTNER OS - Environment Configuration
# Copy this file to .env and update values before deployment
# ============================================================================

# --- Application ---
NODE_ENV=production
API_PORT=5000
WEB_PORT=80
WEB_SSL_PORT=443

# --- Database ---
DB_NAME=trustner_partner_os
DB_USER=trustner_admin
DB_PASSWORD=CHANGE_THIS_TO_STRONG_PASSWORD
DB_PORT=5432
DATABASE_URL=postgresql://trustner_admin:CHANGE_THIS@postgres:5432/trustner_partner_os?schema=public

# --- Redis ---
REDIS_PASSWORD=CHANGE_THIS_TO_STRONG_PASSWORD
REDIS_PORT=6379
REDIS_URL=redis://:CHANGE_THIS@redis:6379

# --- JWT Authentication ---
JWT_SECRET=CHANGE_THIS_TO_64_CHAR_RANDOM_STRING
JWT_EXPIRY=1h
JWT_REFRESH_EXPIRY=7d

# --- Encryption (PAN, Aadhaar, Bank details) ---
ENCRYPTION_KEY=CHANGE_THIS_TO_32_CHAR_AES_KEY

# --- CORS ---
ALLOWED_ORIGINS=http://localhost,https://app.trustner.in

# --- BSE Star MF API (Apply at bsestarmf.in) ---
BSE_API_URL=https://www.bsestarmf.in/ServerAPI
BSE_USER_ID=
BSE_PASSWORD=
BSE_MEMBER_CODE=
BSE_PASS_KEY=

# --- KYC APIs ---
CKYC_API_URL=
CKYC_API_KEY=
DIGILOCKER_CLIENT_ID=
DIGILOCKER_CLIENT_SECRET=

# --- Payment Gateway (Razorpay) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# --- SMS API (e.g., MSG91) ---
SMS_API_KEY=
SMS_SENDER_ID=TRUSTR
SMS_TEMPLATE_ID=

# --- Email SMTP ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=notifications@trustner.in
SMTP_PASS=
SMTP_FROM=Trustner Partner OS <notifications@trustner.in>

# --- WhatsApp Business API (Wati/AiSensy) ---
WHATSAPP_API_URL=
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=

# --- File Storage (S3/DigitalOcean Spaces) ---
STORAGE_TYPE=local
S3_BUCKET=
S3_REGION=ap-south-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=

# --- Analytics ---
MIXPANEL_TOKEN=
GA_TRACKING_ID=
