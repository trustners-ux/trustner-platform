  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  company         InsuranceCompany @relation(fields: [companyId], references: [id])
  policies        InsurancePolicy[]
  leads           InsuranceLead[]
  commissionSlabs InsuranceCommissionSlab[]

  @@index([companyId])
  @@index([lob])
  @@index([isActive])
}

// ============================================================================
// MODULE 21: LEAD MANAGEMENT (INSURANCE SALES FUNNEL)
// ============================================================================

model InsuranceLead {
  id                  String      @id @default(cuid())
  leadCode            String      @unique // LEAD-INS-20260225-00001
  pospId              String?
  assignedToUserId    String?

  // Customer Info
  customerName        String
  customerPhone       String
  customerEmail       String?
  customerCity        String?
  customerState       String?
  customerPincode     String?
  dateOfBirth         DateTime?

  // Lead Details
  lob                 InsuranceLOB
  productId           String?
  source              LeadSource   @default(OTHER)
  status              LeadStatus   @default(NEW)
  isRenewal           Boolean      @default(false)
  existingPolicyNumber String?

  // Motor Specific
  vehicleRegNumber    String?
  vehicleMake         String?
  vehicleModel        String?
  vehicleVariant      String?
  vehicleYear         Int?
  vehicleFuelType     String?
  previousInsurer     String?
  previousPolicyExpiry DateTime?
  ncbPercentage       Decimal?    @db.Decimal(5, 2)
  idv                 Decimal?    @db.Decimal(12, 2) // Insured Declared Value

  // Health Specific
  membersCount        Int?
  membersDetails      Json?       // Array of {name, age, relation, preExisting}
  sumInsuredRequired  Decimal?    @db.Decimal(18, 2)

  // Life Specific
  annualIncome        Decimal?    @db.Decimal(18, 2)
  smokingStatus       String?     // SMOKER, NON_SMOKER
  coverRequired       Decimal?    @db.Decimal(18, 2)

  // Quote & Proposal
  quotedPremium       Decimal?    @db.Decimal(12, 2)
  quoteReferenceId    String?
  proposalId          String?
  lastDropOffStage    String?     // Where user left the journey

  // Tracking
  followUpDate        DateTime?
  followUpNotes       String?
  lostReason          String?
  convertedPolicyId   String?
  priorityScore       Int         @default(50) // 1-100 lead scoring

  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  // Relations
  posp                POSPAgent?  @relation(fields: [pospId], references: [id])
  product             InsuranceProduct? @relation(fields: [productId], references: [id])
  activities          LeadActivity[]
  quotes              InsuranceQuote[]

  @@index([pospId])
  @@index([status])
  @@index([lob])
  @@index([source])
  @@index([followUpDate])
  @@index([customerPhone])
}

model LeadActivity {
  id          String    @id @default(cuid())
  leadId      String
  action      String    // CALLED, EMAILED, WHATSAPP_SENT, QUOTE_SHARED, FOLLOW_UP_SET, STATUS_CHANGED, NOTE_ADDED
  description String?
  performedBy String
  createdAt   DateTime  @default(now())

  lead        InsuranceLead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
}

model InsuranceQuote {
  id              String    @id @default(cuid())
