// ============================================================================
// MODULE 20: INSURANCE COMPANIES & PRODUCTS
// ============================================================================

model InsuranceCompany {
  id              String    @id @default(cuid())
  companyCode     String    @unique
  companyName     String
  shortName       String?
  irdaiRegNumber  String?
  companyType     String    // LIFE, GENERAL, HEALTH, STANDALONE_HEALTH
  logoUrl         String?
  apiIntegrated   Boolean   @default(false)
  apiProvider     String?   // VJ_INFOSOFT, DIRECT, HEPH, etc.
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  products        InsuranceProduct[]
  policies        InsurancePolicy[]
  commissionSlabs InsuranceCommissionSlab[]

  @@index([companyType])
}

model InsuranceProduct {
  id              String        @id @default(cuid())
  companyId       String
  productCode     String        @unique
  productName     String
  lob             InsuranceLOB
  planType        String?       // BASE, TOP_UP, SUPER_TOP_UP, ADD_ON
  description     String?
  minAge          Int?
  maxAge          Int?
  minSumInsured   Decimal?      @db.Decimal(18, 2)
  maxSumInsured   Decimal?      @db.Decimal(18, 2)
  minPremium      Decimal?      @db.Decimal(12, 2)
  maxPremium      Decimal?      @db.Decimal(12, 2)
  policyTerm      Int?          // in years
  waitingPeriod   Int?          // in days
  claimSettlement Decimal?      @db.Decimal(5, 2) // CSR percentage
  brochureUrl     String?
  featureMatrix   Json?         // Key features as structured data
