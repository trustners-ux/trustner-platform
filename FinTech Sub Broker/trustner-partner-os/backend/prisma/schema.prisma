// ============================================================================
// MODULE 1: USER & AUTHENTICATION
// ============================================================================

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  phone           String    @unique
  passwordHash    String
  role            UserRole
  isActive        Boolean   @default(true)
  isEmailVerified Boolean   @default(false)
  isPhoneVerified Boolean   @default(false)
  twoFactorEnabled Boolean  @default(false)
  twoFactorSecret String?
  lastLoginAt     DateTime?
  lastLoginIp     String?
  failedAttempts  Int       @default(0)
  lockedUntil     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  profile         UserProfile?
  subBroker       SubBroker?
  client          Client?
  pospAgent       POSPAgent?
  sessions        UserSession[]
  auditLogs       AuditLog[]
  notifications   Notification[]

  @@index([email])
  @@index([phone])
  @@index([role, isActive])
}

model UserProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  firstName     String
  lastName      String
  displayName   String?
  dateOfBirth   DateTime?
  gender        String?
  avatarUrl     String?
  addressLine1  String?
  addressLine2  String?
  city          String?
  state         String?
  pincode       String?
  country       String   @default("IN")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserSession {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  refreshToken String   @unique
  deviceInfo   String?
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

// ============================================================================
// MODULE 2: SUB-BROKER / PARTNER MANAGEMENT (MF)
// ============================================================================

model SubBroker {
  id                String          @id @default(cuid())
  userId            String          @unique
  code              String          @unique  // TRUSTNER-SB-001
  arnNumber         String?
  arnValidTill      DateTime?
  euinNumber        String?
  euinValidTill     DateTime?
  nismCertNumber    String?
  nismValidTill     DateTime?
  pospLicenseNumber String?
  pospValidTill     DateTime?
  panNumber         String?         // Encrypted
  gstNumber         String?
  bankAccountName   String?
  bankAccountNumber String?         // Encrypted
  bankIfscCode      String?
  bankName          String?
  branchId          String?
  regionalHeadId    String?
  status            SubBrokerStatus @default(PENDING_APPROVAL)
  approvedAt        DateTime?
  approvedBy        String?
  commissionTier    CommissionTier  @default(STARTER)
  revenueSharePct   Decimal         @default(50.00) @db.Decimal(5, 2)
  agreementSignedAt DateTime?
  remarks           String?
  totalAum          Decimal         @default(0) @db.Decimal(18, 2)
  totalClients      Int             @default(0)
  totalSipBook      Decimal         @default(0) @db.Decimal(18, 2)
  joiningDate       DateTime        @default(now())
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  // Relations
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch            Branch?         @relation(fields: [branchId], references: [id])
  clients           Client[]
  documents         Document[]
  commissions       Commission[]
  payouts           Payout[]
  aumRecords        AumRecord[]
  sipRegistrations  SIPRegistration[]
  complianceAlerts  ComplianceAlert[]
  marketingAssets   MarketingAsset[]
  targets           PartnerTarget[]
  referrals         Referral[]      @relation("ReferredBy")
  referredBy        Referral?       @relation("ReferredTo")
  // Cross-reference to POSP: A SubBroker can also be a POSP Agent
  pospAgent         POSPAgent?

  @@index([status])
  @@index([arnNumber])
  @@index([branchId])
  @@index([regionalHeadId])
  @@index([commissionTier])
}

model Branch {
  id          String     @id @default(cuid())
  code        String     @unique
  name        String
  type        BranchType
  address     String?
  city        String
  state       String
  pincode     String?
  headId      String?    // Regional Head userId
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  subBrokers  SubBroker[]

  @@index([city, state])
}

// ============================================================================
// MODULE 3: CLIENT MANAGEMENT & KYC (MF)
// ============================================================================

model Client {
  id                String       @id @default(cuid())
  userId            String       @unique
  subBrokerId       String
  clientCode        String       @unique  // TRUSTNER-C-00001
  panNumber         String?      // Encrypted
  aadhaarNumber     String?      // Encrypted (last 4 stored)
  aadhaarRefId      String?
  taxStatus         String       @default("INDIVIDUAL")
  occupation        String?
  annualIncome      String?
  kycStatus         KYCStatus    @default(NOT_STARTED)
  ckycNumber        String?
  riskProfile       RiskProfile?
  riskScore         Int?
  riskAssessedAt    DateTime?
  bseClientCode     String?      // BSE Star MF client code
  nseClientCode     String?
  nomineeDetails    Json?
  fatcaCompliant    Boolean      @default(false)
  status            ClientStatus @default(PROSPECT)
  totalInvested     Decimal      @default(0) @db.Decimal(18, 2)
  currentValue      Decimal      @default(0) @db.Decimal(18, 2)
  totalSipAmount    Decimal      @default(0) @db.Decimal(18, 2)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  // Relations
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subBroker         SubBroker    @relation(fields: [subBrokerId], references: [id])
  bankAccounts      ClientBankAccount[]
  documents         Document[]
  transactions      Transaction[]
  sipRegistrations  SIPRegistration[]
  holdings          Holding[]
  goals             InvestmentGoal[]
  riskAssessments   RiskAssessment[]

  @@index([subBrokerId])
  @@index([panNumber])
  @@index([kycStatus])
  @@index([status])
  @@index([bseClientCode])
}

model ClientBankAccount {
  id              String   @id @default(cuid())
  clientId        String
  accountNumber   String   // Encrypted
  ifscCode        String
  bankName        String
  branchName      String?
  accountType     String   @default("SAVINGS")
  isVerified      Boolean  @default(false)
  isPrimary       Boolean  @default(false)
  verifiedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model RiskAssessment {
  id            String      @id @default(cuid())
  clientId      String
  responses     Json        // Array of {questionId, answer, score}
  totalScore    Int
  riskProfile   RiskProfile
  suggestedAllocation Json  // {equity: 60, debt: 30, gold: 10}
  assessedAt    DateTime    @default(now())

  client        Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

// ============================================================================
// MODULE 4: MUTUAL FUND SCHEMES & NAV
// ============================================================================

model MutualFundScheme {
  id              String    @id @default(cuid())
  schemeCode      String    @unique  // BSE/AMFI scheme code
  amfiCode        String?
  schemeName      String
  amcName         String
  amcCode         String?
  category        String    // Equity, Debt, Hybrid, etc.
  subCategory     String?   // Large Cap, Mid Cap, etc.
  schemeType      String    // Open-ended, Close-ended
  planType        String    // DIRECT, REGULAR
  optionType      String    // GROWTH, IDCW
  riskCategory    String?   // Low, Moderate, High, Very High
  latestNav       Decimal?  @db.Decimal(12, 4)
  navDate         DateTime?
  aum             Decimal?  @db.Decimal(18, 2)
  expenseRatio    Decimal?  @db.Decimal(5, 4)
  minLumpsum      Decimal?  @db.Decimal(12, 2)
  minSip          Decimal?  @db.Decimal(12, 2)
  minSipFrequency String?
  exitLoad        String?
  lockInPeriod    Int?      // in days
  benchmarkIndex  String?
  fundManagerName String?
  launchDate      DateTime?
  isActive        Boolean   @default(true)
  sipAllowed      Boolean   @default(true)
  stpAllowed      Boolean   @default(true)
  swpAllowed      Boolean   @default(true)
  switchAllowed   Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  navHistory      NavHistory[]
  holdings        Holding[]
  transactions    Transaction[]
  sipRegistrations SIPRegistration[]
  commissionRates  SchemeCommissionRate[]

  @@index([schemeCode])
  @@index([amcCode])
  @@index([category, subCategory])
  @@index([planType])
  @@index([isActive])
}

model NavHistory {
  id          String   @id @default(cuid())
  schemeId    String
  nav         Decimal  @db.Decimal(12, 4)
  navDate     DateTime
  createdAt   DateTime @default(now())

  scheme      MutualFundScheme @relation(fields: [schemeId], references: [id])

  @@unique([schemeId, navDate])
  @@index([schemeId, navDate])
}

// ============================================================================
// MODULE 5: TRANSACTIONS (MF)
// ============================================================================

model Transaction {
  id                  String            @id @default(cuid())
  transactionCode     String            @unique // TXN-20260225-00001
  clientId            String
  subBrokerId         String?
  schemeId            String
  type                TransactionType
  amount              Decimal           @db.Decimal(18, 2)
  units               Decimal?          @db.Decimal(18, 4)
  nav                 Decimal?          @db.Decimal(12, 4)
  folioNumber         String?
  bseOrderId          String?
  bseOrderStatus      String?
  paymentMode         String?           // NETBANKING, UPI, NACH
  paymentRefId        String?
  stampDuty           Decimal?          @db.Decimal(12, 2)
  stt                 Decimal?          @db.Decimal(12, 2)
  exitLoadAmount      Decimal?          @db.Decimal(12, 2)
  status              TransactionStatus @default(INITIATED)
  remarks             String?
  switchToSchemeId    String?
  stpToSchemeId       String?
  allotmentDate       DateTime?
  allotmentNav        Decimal?          @db.Decimal(12, 4)
  allotmentUnits      Decimal?          @db.Decimal(18, 4)
  failureReason       String?
  submittedAt         DateTime?
  completedAt         DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  // Relations
  client              Client            @relation(fields: [clientId], references: [id])
  scheme              MutualFundScheme  @relation(fields: [schemeId], references: [id])

  @@index([clientId])
  @@index([subBrokerId])
  @@index([type])
  @@index([status])
  @@index([bseOrderId])
  @@index([createdAt])
}

// ============================================================================
// MODULE 6: SIP MANAGEMENT (MF)
// ============================================================================

model SIPRegistration {
  id                String       @id @default(cuid())
  sipCode           String       @unique // SIP-20260225-00001
  clientId          String
  subBrokerId       String
  schemeId          String
  amount            Decimal      @db.Decimal(18, 2)
  frequency         SIPFrequency @default(MONTHLY)
  sipDate           Int          // Day of month (1-28)
  startDate         DateTime
  endDate           DateTime?
  totalInstallments Int?
  completedInstallments Int      @default(0)
  missedInstallments    Int      @default(0)
  mandateId         String?
  bseSipRegId       String?      // BSE SIP Registration ID
  folioNumber       String?
  status            SIPStatus    @default(ACTIVE)
  nextDueDate       DateTime?
  lastProcessedDate DateTime?
  totalInvested     Decimal      @default(0) @db.Decimal(18, 2)
  pausedAt          DateTime?
  cancelledAt       DateTime?
  remarks           String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  // Relations
  client            Client       @relation(fields: [clientId], references: [id])
  subBroker         SubBroker    @relation(fields: [subBrokerId], references: [id])
  scheme            MutualFundScheme @relation(fields: [schemeId], references: [id])
  mandate           Mandate?     @relation(fields: [mandateId], references: [id])
  installments      SIPInstallment[]

  @@index([clientId])
  @@index([subBrokerId])
  @@index([status])
  @@index([nextDueDate])
}

model SIPInstallment {
  id              String   @id @default(cuid())
  sipId           String
  installmentNo   Int
  dueDate         DateTime
  amount          Decimal  @db.Decimal(18, 2)
  status          String   @default("PENDING") // PENDING, SUCCESS, FAILED, BOUNCED
  transactionId   String?
  nav             Decimal? @db.Decimal(12, 4)
  units           Decimal? @db.Decimal(18, 4)
  failureReason   String?
  processedAt     DateTime?
  createdAt       DateTime @default(now())

  sip             SIPRegistration @relation(fields: [sipId], references: [id], onDelete: Cascade)

  @@unique([sipId, installmentNo])
  @@index([sipId])
  @@index([dueDate, status])
}

// ============================================================================
// MODULE 7: MANDATE / NACH / eMANDATE (MF)
// ============================================================================

model Mandate {
  id              String        @id @default(cuid())
  clientId        String
  mandateType     MandateType
  mandateRefId    String?       @unique  // BSE/Bank mandate reference
  bankAccountId   String?
  amount          Decimal       @db.Decimal(18, 2) // Max mandate amount
  startDate       DateTime
  endDate         DateTime
  status          MandateStatus @default(PENDING)
  approvedAt      DateTime?
  cancelledAt     DateTime?
  remarks         String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  sipRegistrations SIPRegistration[]

  @@index([clientId])
  @@index([status])
}

// ============================================================================
// MODULE 8: PORTFOLIO HOLDINGS (MF)
// ============================================================================

model Holding {
  id              String   @id @default(cuid())
  clientId        String
  schemeId        String
  folioNumber     String
  units           Decimal  @db.Decimal(18, 4)
  investedAmount  Decimal  @db.Decimal(18, 2)
  currentValue    Decimal  @db.Decimal(18, 2)
  currentNav      Decimal  @db.Decimal(12, 4)
  avgNav          Decimal  @db.Decimal(12, 4)
  absoluteReturn  Decimal? @db.Decimal(10, 4) // percentage
  xirr            Decimal? @db.Decimal(10, 4) // percentage
  lastUpdatedAt   DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  client          Client   @relation(fields: [clientId], references: [id])
  scheme          MutualFundScheme @relation(fields: [schemeId], references: [id])

  @@unique([clientId, schemeId, folioNumber])
  @@index([clientId])
}

// ============================================================================
// MODULE 9: INVESTMENT GOALS (MF)
// ============================================================================

model InvestmentGoal {
  id              String    @id @default(cuid())
  clientId        String
  goalName        String    // Retirement, Child Education, etc.
  targetAmount    Decimal   @db.Decimal(18, 2)
  targetDate      DateTime
  currentValue    Decimal   @default(0) @db.Decimal(18, 2)
  monthlySip      Decimal?  @db.Decimal(18, 2)
  riskProfile     RiskProfile?
  allocation      Json?     // {equity: %, debt: %, gold: %}
  linkedSchemes   Json?     // Array of schemeIds
  progressPct     Decimal   @default(0) @db.Decimal(5, 2)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  client          Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

// ============================================================================
// MODULE 10: COMMISSION ENGINE (MF)
// ============================================================================

model SchemeCommissionRate {
  id              String   @id @default(cuid())
  schemeId        String
  commissionType  CommissionType
  ratePct         Decimal  @db.Decimal(8, 4) // Commission rate %
  effectiveFrom   DateTime
  effectiveTo     DateTime?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  scheme          MutualFundScheme @relation(fields: [schemeId], references: [id])

  @@index([schemeId, commissionType, isActive])
}

model Commission {
  id                String           @id @default(cuid())
  subBrokerId       String
  clientId          String?
  schemeCode        String?
  schemeName        String?
  folioNumber       String?
  transactionType   String?
  grossAmount       Decimal          @db.Decimal(18, 4)  // From AMC/RTA
  tdsAmount         Decimal          @default(0) @db.Decimal(18, 4)
  gstAmount         Decimal          @default(0) @db.Decimal(18, 4)
  netAmount         Decimal          @db.Decimal(18, 4)  // After TDS
  subBrokerShare    Decimal          @db.Decimal(18, 4)  // Sub-broker's portion
  trustnerShare     Decimal          @db.Decimal(18, 4)  // Trustner's retention
  revenueSharePct   Decimal          @db.Decimal(5, 2)   // Applied %
  commissionType    CommissionType
  status            CommissionStatus @default(PENDING)
  periodMonth       Int              // 1-12
  periodYear        Int
  rtaSource         String?          // CAMS, Karvy/KFintech
  rtaFileRef        String?
  clawbackRefId     String?          // Original commission ID if clawback
  isClawback        Boolean          @default(false)
  arnSplitApplied   Boolean          @default(false)
  calculatedAt      DateTime?
  approvedAt        DateTime?
  approvedBy        String?
  remarks           String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  // Relations
  subBroker         SubBroker        @relation(fields: [subBrokerId], references: [id])
  payoutItems       PayoutItem[]

  @@index([subBrokerId])
  @@index([commissionType])
  @@index([status])
  @@index([periodMonth, periodYear])
  @@index([rtaSource])
}

model Payout {
  id              String       @id @default(cuid())
  subBrokerId     String
  payoutCode      String       @unique // PAY-202602-001
  periodMonth     Int
  periodYear      Int
  grossAmount     Decimal      @db.Decimal(18, 4)
  tdsAmount       Decimal      @db.Decimal(18, 4)
  gstAmount       Decimal      @db.Decimal(18, 4)
  netPayable      Decimal      @db.Decimal(18, 4)
  clawbackAmount  Decimal      @default(0) @db.Decimal(18, 4)
  finalAmount     Decimal      @db.Decimal(18, 4)
  bankRefNumber   String?
  paidAt          DateTime?
  status          PayoutStatus @default(PENDING)
  approvedBy      String?
  approvedAt      DateTime?
  statementUrl    String?      // PDF statement path
  excelUrl        String?      // Excel export path
  remarks         String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Relations
  subBroker       SubBroker    @relation(fields: [subBrokerId], references: [id])
  items           PayoutItem[]

  @@unique([subBrokerId, periodMonth, periodYear])
  @@index([subBrokerId])
  @@index([status])
  @@index([periodMonth, periodYear])
}

model PayoutItem {
  id            String     @id @default(cuid())
  payoutId      String
  commissionId  String

  payout        Payout     @relation(fields: [payoutId], references: [id], onDelete: Cascade)
  commission    Commission @relation(fields: [commissionId], references: [id])

  @@unique([payoutId, commissionId])
}

