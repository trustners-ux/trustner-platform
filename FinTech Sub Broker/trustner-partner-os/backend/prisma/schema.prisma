  insurerName     String
  productName     String
  sumInsured      Decimal   @db.Decimal(18, 2)
  premium         Decimal   @db.Decimal(12, 2)
  gst             Decimal   @db.Decimal(12, 2)
  totalPremium    Decimal   @db.Decimal(12, 2)
  coverageDetails Json?     // Structured coverage breakdown
  addOns          Json?     // Selected add-ons
  quoteRefId      String?
  validTill       DateTime?
  isSelected      Boolean   @default(false)
  createdAt       DateTime  @default(now())

  lead            InsuranceLead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
}

// ============================================================================
// MODULE 22: POLICY MANAGEMENT (STATE MACHINE)
// ============================================================================

model InsurancePolicy {
  id                  String        @id @default(cuid())
  policyNumber        String        @unique
  internalRefCode     String        @unique // TIBPL-POL-20260225-00001
  pospId              String
  customerId          String?       // Link to Client model if exists
  companyId           String
  productId           String

  // Customer Details (denormalized for quick access)
  customerName        String
  customerPhone       String
  customerEmail       String?
  customerPan         String?       // Encrypted
  customerAadhaar     String?       // Encrypted

  // Policy Details
  lob                 InsuranceLOB
  status              PolicyStatus  @default(QUOTE_GENERATED)
  sumInsured          Decimal       @db.Decimal(18, 2)
  basePremium         Decimal       @db.Decimal(12, 2)
  addOnPremium        Decimal       @default(0) @db.Decimal(12, 2)
  gstAmount           Decimal       @db.Decimal(12, 2)
  totalPremium        Decimal       @db.Decimal(12, 2)
  stampDuty           Decimal       @default(0) @db.Decimal(12, 2)
  netPremium          Decimal       @db.Decimal(12, 2) // Premium for commission calc

  // Dates
  proposalDate        DateTime?
  issuanceDate        DateTime?
  startDate           DateTime?
  endDate             DateTime?
  cancellationDate    DateTime?

  // Motor Specific
  vehicleRegNumber    String?
  vehicleMake         String?
  vehicleModel        String?
  vehicleChassisNo    String?       // Encrypted
  vehicleEngineNo     String?       // Encrypted
  idv                 Decimal?      @db.Decimal(12, 2)
  ncbPercentage       Decimal?      @db.Decimal(5, 2)
  policyType          String?       // TP, OD, COMPREHENSIVE, BREAKIN, ROLLOVER

  // Health Specific
  membersDetails      Json?
  waitingPeriod       Int?
  preExistingConditions Json?

  // Life Specific
  nomineeName         String?
  nomineeRelation     String?
  riderDetails        Json?

  // Payment
  paymentMode         String?       // ONLINE, CHEQUE, NACH
  paymentRefId        String?
  paymentDate         DateTime?

  // Insurer Reference
  insurerProposalNo   String?
  insurerPolicyUrl    String?
  policyDocumentUrl   String?

  // BQP/SP Tagging (IRDAI compliance)
  bqpTagged           Boolean       @default(false)
  bqpCode             String?
  spTagged            Boolean       @default(false)
  spCode              String?

  // Renewal
  renewalStatus       RenewalStatus?
  previousPolicyId    String?
  renewedPolicyId     String?
  renewalReminderSent Boolean       @default(false)

  // Metadata
  remarks             String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  // Relations
  posp                POSPAgent     @relation(fields: [pospId], references: [id])
  company             InsuranceCompany @relation(fields: [companyId], references: [id])
  product             InsuranceProduct @relation(fields: [productId], references: [id])
  endorsements        Endorsement[]
  claims              InsuranceClaim[]
  commissions         InsuranceCommission[]
  statusHistory       PolicyStatusHistory[]
  documents           PolicyDocument[]
  inspections         VehicleInspection[]

  @@index([pospId])
  @@index([companyId])
  @@index([lob])
  @@index([status])
  @@index([endDate])
  @@index([renewalStatus])
  @@index([customerPhone])
  @@index([vehicleRegNumber])
  @@index([policyNumber])
}

