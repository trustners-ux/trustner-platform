// ============================================================================
// TRUSTNER PARTNER OS - Complete Unified Database Schema
// B2B2C Fintech Distribution Platform + Insurance Broking Module
// Scalable to 100,000+ users | IPO-Ready Architecture
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

