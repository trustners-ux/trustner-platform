  isCompleted     Boolean   @default(false)
  createdAt       DateTime  @default(now())

  posp            POSPAgent @relation(fields: [pospId], references: [id], onDelete: Cascade)

  @@index([pospId])
}

model POSPDocument {
  id              String    @id @default(cuid())
  pospId          String
  documentType    String    // PAN, AADHAAR, PHOTO, QUALIFICATION, IRDAI_CERT, BANK_PROOF
  fileName        String
  filePath        String
  fileSize        Int?
  mimeType        String?
  isVerified      Boolean   @default(false)
  verifiedAt      DateTime?
  verifiedBy      String?
  remarks         String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  posp            POSPAgent @relation(fields: [pospId], references: [id], onDelete: Cascade)

  @@index([pospId])
}

model POSPTarget {
  id                  String    @id @default(cuid())
  pospId              String
  month               Int
  year                Int
  premiumTarget       Decimal   @db.Decimal(18, 2)
  policyCountTarget   Int
  premiumAchieved     Decimal   @default(0) @db.Decimal(18, 2)
  policyCountAchieved Int       @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  posp                POSPAgent @relation(fields: [pospId], references: [id])

