// ============================================================================
// MODULE 19: POSP / SP / BQP MANAGEMENT
// ============================================================================

model POSPAgent {
  id                  String        @id @default(cuid())
  subBrokerId         String?       @unique // Linked to MF sub-broker if dual role
  userId              String        @unique
  agentCode           String        @unique // TIBPL-POSP-00001
  category            POSPCategory
  status              POSPStatus    @default(APPLICATION_RECEIVED)

  // Personal Details
  firstName           String
  lastName            String
  dateOfBirth         DateTime
  gender              String
  email               String
  phone               String
  panNumber           String?       // Encrypted
  aadhaarNumber       String?       // Encrypted (last 4)
  addressLine1        String?
  addressLine2        String?
  city                String?
  state               String?
  pincode             String?

  // IRDAI Registration
  irdaiLicenseNumber  String?
  irdaiLicenseDate    DateTime?
  irdaiExpiryDate     DateTime?
  spCode              String?       // SP Registration (if applicable)
  bqpCode             String?       // BQP Registration (if applicable)

  // Training & Certification
  trainingStartDate   DateTime?
  trainingEndDate     DateTime?
  trainingHoursCompleted Decimal   @default(0) @db.Decimal(5, 1) // Out of 15 hours
  examDate            DateTime?
  examScore           Int?
  examAttempts        Int           @default(0)
  certificateNumber   String?
  certificateIssuedAt DateTime?
  certificateExpiryAt DateTime?

  // Bank Details (for commission payout)
  bankAccountName     String?
  bankAccountNumber   String?       // Encrypted
  bankIfscCode        String?
  bankName            String?

  // Hierarchy
  branchId            String?
  reportingManagerId  String?
  regionId            String?

  // Performance
  totalPoliciesSold   Int           @default(0)
  totalPremiumGenerated Decimal     @default(0) @db.Decimal(18, 2)
  totalCommissionEarned Decimal     @default(0) @db.Decimal(18, 2)
  activePolicies      Int           @default(0)
  renewalRate         Decimal       @default(0) @db.Decimal(5, 2) // percentage

  // Metadata
  approvedAt          DateTime?
  approvedBy          String?
  terminatedAt        DateTime?
  terminationReason   String?
  remarks             String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  // Relations
  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subBroker           SubBroker?    @relation(fields: [subBrokerId], references: [id])
  leads               InsuranceLead[]
  policies            InsurancePolicy[]
  commissions         InsuranceCommission[]
  payouts             InsurancePayout[]
  trainingRecords     POSPTrainingRecord[]
  documents           POSPDocument[]
  targets             POSPTarget[]
  tickets             SupportTicket[]  @relation("TicketAgent")

  @@index([status])
  @@index([category])
  @@index([irdaiLicenseNumber])
  @@index([branchId])
  @@index([subBrokerId])
}

model POSPTrainingRecord {
