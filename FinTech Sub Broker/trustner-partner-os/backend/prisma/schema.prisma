  claimCode           String      @unique // CLM-20260225-00001
  policyId            String
  pospId              String?

  // Claim Details
  claimType           String      // CASHLESS, REIMBURSEMENT, OWN_DAMAGE, THIRD_PARTY, DEATH, MATURITY
  status              ClaimStatus @default(INTIMATED)
  incidentDate        DateTime
  intimationDate      DateTime    @default(now())
  description         String
  estimatedAmount     Decimal?    @db.Decimal(18, 2)
  claimedAmount       Decimal?    @db.Decimal(18, 2)
  approvedAmount      Decimal?    @db.Decimal(18, 2)
  settledAmount       Decimal?    @db.Decimal(18, 2)
  deductionAmount     Decimal?    @db.Decimal(18, 2)
  deductionReason     String?

  // Hospital/Garage Details (Health/Motor)
  providerName        String?     // Hospital or Garage name
  providerCity        String?
  providerState       String?
  admissionDate       DateTime?
  dischargeDate       DateTime?

  // Surveyor Details (Motor)
  surveyorName        String?
  surveyorPhone       String?
  surveyorReportUrl   String?
  surveyDate          DateTime?

  // Insurer Reference
  insurerClaimNumber  String?
  insurerRemarks      String?

  // Resolution
  rejectionReason     String?
  settledAt           DateTime?
  closedAt            DateTime?
  closedBy            String?

  // Allocated to
  assignedToUserId    String?

  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  // Relations
  policy              InsurancePolicy @relation(fields: [policyId], references: [id])
  documents           ClaimDocument[]
  statusHistory       ClaimStatusHistory[]

  @@index([policyId])
  @@index([status])
  @@index([claimType])
  @@index([assignedToUserId])
}

model ClaimDocument {
  id            String    @id @default(cuid())
  claimId       String
  documentType  String    // CLAIM_FORM, HOSPITAL_BILL, DISCHARGE_SUMMARY, FIR, SURVEY_REPORT, REPAIR_ESTIMATE, etc.
  fileName      String
  filePath      String
  fileSize      Int?
  isVerified    Boolean   @default(false)
  verifiedBy    String?
  remarks       String?
  createdAt     DateTime  @default(now())

  claim         InsuranceClaim @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@index([claimId])
}

model ClaimStatusHistory {
  id          String   @id @default(cuid())
  claimId     String
  fromStatus  String
  toStatus    String
  changedBy   String
  reason      String?
  createdAt   DateTime @default(now())

  claim       InsuranceClaim @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@index([claimId])
}

// ============================================================================
// MODULE 25: ENDORSEMENTS
// ============================================================================

model Endorsement {
  id                  String            @id @default(cuid())
  endorsementCode     String            @unique // END-20260225-00001
  policyId            String
  type                EndorsementType
  status              EndorsementStatus @default(REQUESTED)
  description         String
  requestedChanges    Json              // {field: oldValue, newValue}
  oldValues           Json?
  newValues           Json?
  premiumDifference   Decimal?          @db.Decimal(12, 2)
  additionalPremium   Decimal?          @db.Decimal(12, 2)
  refundAmount        Decimal?          @db.Decimal(12, 2)
  endorsementDate     DateTime?
  insurerEndorsementNo String?
  requestedBy         String
  processedBy         String?
  processedAt         DateTime?
  rejectionReason     String?
  assignedToUserId    String?
  remarks             String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  // Relations
  policy              InsurancePolicy   @relation(fields: [policyId], references: [id])
  documents           EndorsementDocument[]
  statusHistory       EndorsementStatusHistory[]

  @@index([policyId])
  @@index([status])
  @@index([type])
  @@index([assignedToUserId])
}

model EndorsementDocument {
  id            String    @id @default(cuid())
  endorsementId String
  documentType  String
  fileName      String
  filePath      String
  fileSize      Int?
  isVerified    Boolean   @default(false)
  createdAt     DateTime  @default(now())

  endorsement   Endorsement @relation(fields: [endorsementId], references: [id], onDelete: Cascade)

  @@index([endorsementId])
}

model EndorsementStatusHistory {
  id              String   @id @default(cuid())
  endorsementId   String
  fromStatus      String
  toStatus        String
  changedBy       String
  reason          String?
  createdAt       DateTime @default(now())

  endorsement     Endorsement @relation(fields: [endorsementId], references: [id], onDelete: Cascade)

  @@index([endorsementId])
}

// ============================================================================
// MODULE 26: INSURANCE COMMISSION ENGINE (SLAB-BASED)
// ============================================================================

model InsuranceCommissionSlab {
  id              String    @id @default(cuid())
  companyId       String
  productId       String?   // null = applies to all products of company
  lob             InsuranceLOB
  commissionType  InsuranceCommissionType
  slabName        String    // e.g., "0-25L", "25L-50L", "50L-1Cr"
  minPremium      Decimal   @db.Decimal(18, 2) // Slab start (cumulative premium)
  maxPremium      Decimal   @db.Decimal(18, 2) // Slab end
  brokerRate      Decimal   @db.Decimal(8, 4)  // % commission for Trustner from insurer
  pospShareRate   Decimal   @db.Decimal(8, 4)  // % of broker commission shared with POSP
  effectiveFrom   DateTime
  effectiveTo     DateTime?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  company         InsuranceCompany  @relation(fields: [companyId], references: [id])
  product         InsuranceProduct? @relation(fields: [productId], references: [id])

  @@index([companyId, lob, isActive])
  @@index([productId])
}

model InsuranceCommission {
  id                  String                  @id @default(cuid())
  policyId            String
  pospId              String
  companyId           String?
  commissionType      InsuranceCommissionType
  netPremium          Decimal                 @db.Decimal(18, 2)
  brokerCommissionPct Decimal                 @db.Decimal(8, 4) // % from insurer
  brokerCommissionAmt Decimal                 @db.Decimal(18, 4) // Total broker commission
  pospSharePct        Decimal                 @db.Decimal(8, 4) // POSP's share %
  pospCommissionAmt   Decimal                 @db.Decimal(18, 4) // POSP's commission
  trustnerRetention   Decimal                 @db.Decimal(18, 4) // Trustner's retention
  tdsAmount           Decimal                 @default(0) @db.Decimal(18, 4)
  gstAmount           Decimal                 @default(0) @db.Decimal(18, 4)
  netPayable          Decimal                 @db.Decimal(18, 4) // Final POSP payout
  slabApplied         String?                 // Which slab was used
  status              CommissionStatus        @default(PENDING)
  periodMonth         Int
  periodYear          Int
  receivedFromInsurer Boolean                 @default(false)
  receivedDate        DateTime?
  receivedAmount      Decimal?                @db.Decimal(18, 4)
  reconciled          Boolean                 @default(false)
  isClawback          Boolean                 @default(false)
  clawbackRefId       String?
  remarks             String?
  calculatedAt        DateTime?
  approvedAt          DateTime?
  approvedBy          String?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  // Relations
  policy              InsurancePolicy         @relation(fields: [policyId], references: [id])
  posp                POSPAgent               @relation(fields: [pospId], references: [id])
  payoutItems         InsurancePayoutItem[]

  @@index([pospId])
  @@index([policyId])
  @@index([status])
  @@index([periodMonth, periodYear])
  @@index([commissionType])
}

model InsurancePayout {
  id              String       @id @default(cuid())
  pospId          String
  payoutCode      String       @unique // IPAY-202602-001
  periodMonth     Int
  periodYear      Int
  grossAmount     Decimal      @db.Decimal(18, 4)
  tdsAmount       Decimal      @db.Decimal(18, 4)
  gstAmount       Decimal      @db.Decimal(18, 4)
  clawbackAmount  Decimal      @default(0) @db.Decimal(18, 4)
  netPayable      Decimal      @db.Decimal(18, 4)
  bankRefNumber   String?
  paidAt          DateTime?
  status          PayoutStatus @default(PENDING)
  approvedBy      String?
  approvedAt      DateTime?
  statementUrl    String?
  excelUrl        String?
  remarks         String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  posp            POSPAgent    @relation(fields: [pospId], references: [id])
  items           InsurancePayoutItem[]

  @@unique([pospId, periodMonth, periodYear])
  @@index([pospId])
  @@index([status])
}

model InsurancePayoutItem {
  id              String    @id @default(cuid())
  payoutId        String
  commissionId    String

  payout          InsurancePayout     @relation(fields: [payoutId], references: [id], onDelete: Cascade)
  commission      InsuranceCommission @relation(fields: [commissionId], references: [id])

  @@unique([payoutId, commissionId])
}

// ============================================================================
// MODULE 27: SUPPORT TICKETS
// ============================================================================

model SupportTicket {
  id              String         @id @default(cuid())
  ticketCode      String         @unique // TKT-20260225-00001
  pospId          String?
  customerId      String?
  policyNumber    String?
  category        TicketCategory
  priority        TicketPriority @default(MEDIUM)
  status          TicketStatus   @default(OPEN)
  subject         String
  description     String
  assignedToUserId String?
  resolvedAt      DateTime?
  resolvedBy      String?
  resolution      String?
  slaDeadline     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  posp            POSPAgent?     @relation("TicketAgent", fields: [pospId], references: [id])
  comments        TicketComment[]

  @@index([pospId])
  @@index([status])
  @@index([priority])
  @@index([category])
  @@index([assignedToUserId])
}

model TicketComment {
  id          String   @id @default(cuid())
  ticketId    String
  authorId    String
  authorName  String
  content     String
  isInternal  Boolean  @default(false) // Internal note vs customer-visible
  attachments Json?    // Array of file URLs
  createdAt   DateTime @default(now())

  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

// ============================================================================
// MODULE 28: RENEWALS ENGINE
// ============================================================================

model RenewalTracker {
  id                  String        @id @default(cuid())
  policyId            String        @unique
  pospId              String
  customerName        String
  customerPhone       String
  lob                 InsuranceLOB
  companyName         String
  policyNumber        String
  expiryDate          DateTime
  premiumAmount       Decimal       @db.Decimal(12, 2)
  status              RenewalStatus @default(UPCOMING_90_DAYS)
  reminder90DaySent   Boolean       @default(false)
  reminder60DaySent   Boolean       @default(false)
  reminder30DaySent   Boolean       @default(false)
  reminder15DaySent   Boolean       @default(false)
  reminder7DaySent    Boolean       @default(false)
  reminderDueDaySent  Boolean       @default(false)
  lastContactedAt     DateTime?
  lastContactedBy     String?
  contactNotes        String?
  renewedPolicyId     String?
  lostReason          String?
  competitorName      String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([pospId])
  @@index([expiryDate])
  @@index([status])
  @@index([lob])
}

// ============================================================================
// MODULE 29: VAAHAN INTEGRATION CACHE
// ============================================================================

model VaahanLookup {
  id                  String    @id @default(cuid())
  registrationNumber  String    @unique
  ownerName           String?
  fatherName          String?
  vehicleClass        String?
  maker               String?
  model               String?
  fuelType            String?
  color               String?
  manufacturingDate   DateTime?
  registrationDate    DateTime?
  fitnessUpto         DateTime?
  insuranceUpto       DateTime?
  insuranceCompany    String?
  policyNumber        String?
  chassisNumber       String?   // Masked
  engineNumber        String?   // Masked
  rtoCode             String?
  rtoName             String?
  vehicleAge          Int?
  seatingCapacity     Int?
  grossWeight         Int?
  bodyType            String?
  rawResponse         Json?
  fetchedAt           DateTime  @default(now())
  expiresAt           DateTime  // Cache expiry (24 hours typically)

  @@index([registrationNumber])
  @@index([expiresAt])
}

// ============================================================================
// MODULE 30: IRDAI REGULATORY REPORTS
// ============================================================================

model IRDAIReport {
  id              String    @id @default(cuid())
  reportType      String    // MONTHLY_BUSINESS, QUARTERLY_AUDIT, ANNUAL_RETURN, SP_BQP_LIST, COMPLAINT_REGISTER, CLAIMS_REGISTER
  periodMonth     Int?
  periodYear      Int
  periodQuarter   Int?      // 1-4
  generatedAt     DateTime  @default(now())
  generatedBy     String
  fileUrl         String?
  status          String    @default("GENERATED") // GENERATED, REVIEWED, SUBMITTED
  submittedAt     DateTime?
  submittedBy     String?
  remarks         String?

  @@index([reportType, periodYear])
}

// ============================================================================
// MODULE 31: BULK OFFLINE BOOKING
// ============================================================================

model BulkBooking {
  id              String    @id @default(cuid())
  batchCode       String    @unique // BULK-20260225-001
  uploadedBy      String
  fileName        String
  filePath        String
  totalRecords    Int       @default(0)
  processedRecords Int      @default(0)
  successRecords  Int       @default(0)
  failedRecords   Int       @default(0)
  status          String    @default("UPLOADED") // UPLOADED, VALIDATING, PROCESSING, COMPLETED, FAILED
  errorLog        Json?
  lob             InsuranceLOB
  processedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
  @@index([uploadedBy])
}

// ============================================================================
// MODULE 32: INSURANCE SYSTEM CONFIGURATION
// ============================================================================

model InsuranceConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  category    String   // COMMISSION, RENEWAL, COMPLIANCE, INTEGRATION, GENERAL
  description String?
  isEditable  Boolean  @default(true)
  updatedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
}
