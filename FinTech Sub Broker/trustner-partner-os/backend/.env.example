# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
NODE_ENV=development
PORT=5000
APP_NAME=Trustner Partner OS
APP_VERSION=1.0.0

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL connection string. Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://trustner:trustner@localhost:5432/trustner_partner_os

# =============================================================================
# SECURITY & AUTHENTICATION
# =============================================================================
# JWT Secret key for signing tokens (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
# Access token expiry in seconds (1 hour = 3600)
JWT_ACCESS_EXPIRY=3600
# Refresh token expiry in seconds (7 days = 604800)
JWT_REFRESH_EXPIRY=604800
# Encryption key for sensitive data (32 bytes hex)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://app.trustner.in

# =============================================================================
# REDIS CONFIGURATION (Optional, for caching & sessions)
# =============================================================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# =============================================================================
# BSE INTEGRATION
# =============================================================================
# BSE Star MF API Configuration (Get from BSE)
BSE_API_URL=https://api.bseindia.com/BseStarMF/
BSE_USER_ID=your_bse_user_id
BSE_PASSWORD=your_bse_password
BSE_MEMBER_CODE=your_member_code
BSE_TRANSACTION_ID_PREFIX=TRUSTNER

# =============================================================================
# EXTERNAL API INTEGRATIONS
# =============================================================================
# SMS Gateway (Twilio, AWS SNS, etc.)
SMS_API_URL=https://api.twilio.com/
SMS_API_KEY=your_sms_api_key
SMS_FROM_PHONE=+91XXXXXXXXXX

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@trustner.in
SMTP_PASS=your_smtp_password
SMTP_FROM_EMAIL=noreply@trustner.in
SMTP_FROM_NAME=Trustner Platform

# WhatsApp Business API (Meta/Twilio)
WHATSAPP_API_URL=https://graph.instagram.com/v18.0/
WHATSAPP_API_KEY=your_whatsapp_api_key
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id

# =============================================================================
# COMMISSION & PAYOUT CONFIGURATION
# =============================================================================
# TDS (Tax Deducted at Source) Rate
TDS_RATE=5
# GST (Goods and Services Tax) Rate
GST_RATE=18
# Minimum commission threshold for TDS applicability (in INR)
TDS_THRESHOLD=15000
# Payment gateway for payout processing
PAYMENT_GATEWAY_API_KEY=your_payment_gateway_key
PAYMENT_GATEWAY_URL=https://api.paymentgateway.com

# =============================================================================
# FILE UPLOAD & PROCESSING
# =============================================================================
# Maximum file upload size in MB
MAX_FILE_SIZE=50
# Allowed file types for RTA imports
ALLOWED_RTA_TYPES=csv,xlsx
# Storage path for uploaded files
UPLOAD_DIR=./uploads
# AWS S3 or equivalent cloud storage (optional)
CLOUD_STORAGE_PROVIDER=local
CLOUD_STORAGE_BUCKET=trustner-uploads
CLOUD_STORAGE_REGION=ap-south-1
CLOUD_STORAGE_ACCESS_KEY=
CLOUD_STORAGE_SECRET_KEY=

# =============================================================================
# LOGGING & MONITORING
# =============================================================================
# Log level: error, warn, log, debug, verbose
LOG_LEVEL=log
# Enable request/response logging
LOG_HTTP_REQUESTS=true
# Sentry DSN for error tracking
SENTRY_DSN=

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# Enable/disable features in development
ENABLE_RATE_LIMITING=true
ENABLE_HELMET_SECURITY=true
ENABLE_AUDIT_LOGGING=true
ENABLE_SWAGGER_DOCS=true
# RTA file import sources: CAMS, KFINTECH, FRANKLIN, SBICAP (comma-separated)
ENABLED_RTA_SOURCES=CAMS,KFINTECH

# =============================================================================
# ADMIN CREDENTIALS (SEED SCRIPT)
# =============================================================================
# These are used only during initial database seeding
ADMIN_EMAIL=admin@trustner.in
ADMIN_PASSWORD=TrustnerAdmin@2026
ADMIN_PHONE=+919876543210
COMPLIANCE_ADMIN_EMAIL=compliance@trustner.in
COMPLIANCE_ADMIN_PASSWORD=ComplianceAdmin@2026
FINANCE_ADMIN_EMAIL=finance@trustner.in
FINANCE_ADMIN_PASSWORD=FinanceAdmin@2026
