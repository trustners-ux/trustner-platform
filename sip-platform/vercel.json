{
  "git": {
    "deploymentEnabled": false
  },
  "redirects": [
    {
      "source": "/:path(.*)",
      "has": [{ "type": "host", "value": "merasif.com" }],
      "destination": "https://www.merasip.com/funds/sif",
      "permanent": true
    },
    {
      "source": "/:path(.*)",
      "has": [{ "type": "host", "value": "www.merasif.com" }],
      "destination": "https://www.merasip.com/funds/sif",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/api/(employee|admin)/auth/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "CDN-Cache-Control", "value": "no-store" },
        { "key": "Vercel-CDN-Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/api/admin/users/reset-password",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" },
        { "key": "CDN-Cache-Control", "value": "no-store" },
        { "key": "Vercel-CDN-Cache-Control", "value": "no-store" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/report-reminders",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/report-cleanup",
      "schedule": "0 3 * * 0"
    },
    {
      "path": "/api/cron/nav-update",
      "schedule": "30 3 * * 2-6"
    },
    {
      "path": "/api/cron/refresh-fund-master",
      "schedule": "0 21 * * 6"
    },
    {
      "path": "/api/cron/refresh-nav-only",
      "schedule": "0 23 * * 1-5"
    },
    {
      "path": "/api/cron/universe-metrics",
      "schedule": "30 1 * * 2-6"
    },
    {
      "path": "/api/cron/health-check",
      "schedule": "0 4 * * 1"
    },
    {
      "path": "/api/cron/pd-data-health",
      "schedule": "30 2 * * *"
    },
    {
      "path": "/api/cron/pd-holdings-refresh",
      "schedule": "0 3 12 * *"
    }
  ]
}
